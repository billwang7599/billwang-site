---
// Single blog-post layout. Sits on Base for all shared chrome and prose styling;
// adds the post header (kicker, title, dateline, reading time, tags) and the
// previous/next footer nav. The rendered Markdown body arrives through <slot />.
import Base from './Base.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  slug: string;
  minutes: number;
  prev?: { slug: string; title: string };
  next?: { slug: string; title: string };
  project?: { slug: string; title: string };
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  tags = [],
  slug,
  minutes,
  prev,
  next,
  project,
} = Astro.props;

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const canonical = `https://billwang.dev/writing/${slug}`;
---

<Base
  title={`${title} — Bill Wang`}
  description={description}
  canonical={canonical}
  ogType="article"
  current="writing"
>
  <!-- Typesets the build-time KaTeX output in posts that use math. -->
  <link
    slot="head"
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/katex@0.16.22/dist/katex.min.css"
  />

  <article>
    <header class="post-header">
      <p class="kicker">
        {
          project ? (
            <a href={`/projects/${project.slug}`}>{project.title}</a>
          ) : (
            <a href="/writing">Writing</a>
          )
        }
      </p>
      <h1>{title}</h1>
      <p class="dateline">
        <time datetime={pubDate.toISOString()}>{fmt(pubDate)}</time>
        {updatedDate && <span class="updated"> · updated {fmt(updatedDate)}</span>}
        <span class="updated"> · {minutes} min read</span>
      </p>
      {
        tags.length > 0 && (
          <ul class="tags" aria-label="Tags">
            {tags.map((t) => (
              <li class="pill">{t}</li>
            ))}
          </ul>
        )
      }
    </header>

    <div class="prose">
      <slot />
    </div>

    <nav class="post-nav" aria-label="Post navigation">
      {
        prev ? (
          <a class="prev" href={`/writing/${prev.slug}`}>
            <span class="dir">← Newer</span>
            <span class="ptitle">{prev.title}</span>
          </a>
        ) : (
          <span />
        )
      }
      {
        next ? (
          <a class="next" href={`/writing/${next.slug}`}>
            <span class="dir">Older →</span>
            <span class="ptitle">{next.title}</span>
          </a>
        ) : (
          <span />
        )
      }
    </nav>

    <p class="all-link"><a href="/writing">← All writing</a></p>
  </article>

  <style>
    .post-header {
      margin-bottom: clamp(2.5rem, 7vw, 3.5rem);
    }
    .kicker {
      font-size: 0.72rem;
      letter-spacing: 0.34em;
      text-transform: uppercase;
      color: var(--ink-soft);
      margin-bottom: 1.25rem;
    }
    .kicker a {
      color: var(--ink-soft);
      text-decoration: none;
      transition: color 0.2s ease;
    }
    .kicker a:hover {
      color: var(--ink);
    }
    .post-header h1 {
      font-weight: 500;
      font-size: clamp(2.2rem, 7vw, 3.4rem);
      letter-spacing: 0.01em;
      line-height: 1.08;
    }
    .dateline {
      margin-top: 1rem;
      font-style: italic;
      font-size: clamp(1rem, 2.6vw, 1.1rem);
      color: var(--ink-soft);
    }
    .tags {
      list-style: none;
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 1.1rem;
    }

    .post-nav {
      margin-top: clamp(3rem, 8vw, 4.5rem);
      padding-top: 1.5rem;
      border-top: 1px solid var(--hair);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }
    .post-nav a {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
      text-decoration: none;
      color: var(--ink);
    }
    .post-nav .next {
      text-align: right;
    }
    .post-nav .dir {
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--ink-soft);
    }
    .post-nav .ptitle {
      font-size: 1.05rem;
      border-bottom: 1px solid transparent;
      transition: border-color 0.2s ease;
      width: fit-content;
    }
    .post-nav .next .ptitle {
      margin-left: auto;
    }
    .post-nav a:hover .ptitle {
      border-bottom-color: var(--ink);
    }

    .all-link {
      margin-top: 2rem;
    }
    .all-link a {
      color: var(--ink-soft);
      text-decoration: none;
      font-size: 0.92rem;
      letter-spacing: 0.04em;
      transition: color 0.2s ease;
    }
    .all-link a:hover {
      color: var(--ink);
    }
  </style>
</Base>
