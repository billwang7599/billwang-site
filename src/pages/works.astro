---
// billwang.dev/works — projects and writing, set on the same "bone" stock and
// EB Garamond as the business card. Edit the two arrays below to add entries.

type Project = { title: string; year: string; blurb: string; href?: string };
type Post = { title: string; date: string; href?: string };

const projects: Project[] = [
  {
    title: 'billwang.dev',
    year: '2026',
    blurb:
      'A rotatable 3D business card rendered with Three.js — letterpress relief, real paper grain, the works.',
    href: 'https://github.com/billwang7599',
  },
  // Add more projects here.
];

const posts: Post[] = [
  // { title: 'A first post', date: '2026', href: '/works/first-post' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Bill Wang — works & writing" />
    <title>Bill Wang — Works</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400&display=swap"
    />
  </head>
  <body>
    <main>
      <header class="masthead">
        <a class="home" href="/">&larr; card</a>
        <div class="mark">BILLWANG.DEV</div>
      </header>

      <h1>Works</h1>
      <p class="lede">Projects I&rsquo;ve built and things I&rsquo;ve written.</p>

      <section>
        <h2>Projects</h2>
        {projects.length === 0 ? (
          <p class="empty">Nothing here yet.</p>
        ) : (
          <ul class="entries">
            {projects.map((p) => (
              <li>
                <div class="row">
                  {p.href ? (
                    <a class="title" href={p.href}>{p.title}</a>
                  ) : (
                    <span class="title">{p.title}</span>
                  )}
                  <span class="dots" aria-hidden="true"></span>
                  <span class="year">{p.year}</span>
                </div>
                <p class="blurb">{p.blurb}</p>
              </li>
            ))}
          </ul>
        )}
      </section>

      <section>
        <h2>Writing</h2>
        {posts.length === 0 ? (
          <p class="empty">Coming soon.</p>
        ) : (
          <ul class="entries">
            {posts.map((post) => (
              <li>
                <div class="row">
                  {post.href ? (
                    <a class="title" href={post.href}>{post.title}</a>
                  ) : (
                    <span class="title">{post.title}</span>
                  )}
                  <span class="dots" aria-hidden="true"></span>
                  <span class="year">{post.date}</span>
                </div>
              </li>
            ))}
          </ul>
        )}
      </section>
    </main>

    <style>
      :root {
        --paper: #e8e5da; /* cool bone stock, matching the card */
        --ink: #15161a;
        --ink-soft: #6d7078;
      }
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      html,
      body {
        background: var(--paper);
        color: var(--ink);
        font-family: 'EB Garamond', 'Times New Roman', serif;
        -webkit-font-smoothing: antialiased;
      }
      body {
        min-height: 100vh;
        /* faint vignette so the page reads like a sheet of cool stock */
        background-image: radial-gradient(
          120% 90% at 50% 0%,
          #efede5 0%,
          var(--paper) 55%,
          #dad7cc 100%
        );
      }
      main {
        max-width: 44rem;
        margin: 0 auto;
        padding: clamp(2rem, 6vw, 5rem) clamp(1.25rem, 5vw, 2.5rem) 5rem;
      }

      .masthead {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        margin-bottom: clamp(2.5rem, 8vw, 4.5rem);
      }
      .home {
        font-size: 0.95rem;
        letter-spacing: 0.04em;
        color: var(--ink-soft);
        text-decoration: none;
      }
      .home:hover {
        color: var(--ink);
      }
      .mark {
        font-size: 0.85rem;
        letter-spacing: 0.28em;
        text-transform: uppercase;
        color: var(--ink-soft);
      }

      h1 {
        font-weight: 500;
        font-size: clamp(2.6rem, 9vw, 4rem);
        letter-spacing: 0.06em;
        text-transform: uppercase;
        line-height: 1;
      }
      .lede {
        margin-top: 0.75rem;
        font-size: 1.2rem;
        font-style: italic;
        color: var(--ink-soft);
      }

      section {
        margin-top: clamp(2.5rem, 7vw, 4rem);
      }
      h2 {
        font-weight: 600;
        font-size: 0.8rem;
        letter-spacing: 0.32em;
        text-transform: uppercase;
        color: var(--ink-soft);
        padding-bottom: 0.6rem;
        border-bottom: 1px solid rgba(33, 31, 28, 0.18);
        margin-bottom: 1.25rem;
      }

      .entries {
        list-style: none;
      }
      .entries li + li {
        margin-top: 1.6rem;
      }
      .row {
        display: flex;
        align-items: baseline;
        gap: 0.5rem;
      }
      .title {
        font-size: 1.45rem;
        font-weight: 500;
        color: var(--ink);
        text-decoration: none;
      }
      a.title {
        border-bottom: 1px solid rgba(33, 31, 28, 0.35);
      }
      a.title:hover {
        border-bottom-color: var(--ink);
      }
      .dots {
        flex: 1;
        border-bottom: 1px dotted rgba(33, 31, 28, 0.3);
        transform: translateY(-0.2em);
      }
      .year {
        font-size: 1rem;
        letter-spacing: 0.08em;
        color: var(--ink-soft);
        white-space: nowrap;
      }
      .blurb {
        margin-top: 0.35rem;
        font-size: 1.12rem;
        line-height: 1.5;
        color: #3d3a33;
        max-width: 38rem;
      }
      .empty {
        font-style: italic;
        color: var(--ink-soft);
      }
    </style>
  </body>
</html>
